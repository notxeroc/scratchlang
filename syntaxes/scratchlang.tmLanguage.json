{
  "$schema": "https://githubusercontent.com",
  "name": "Scratchlang",
  "patterns": [
    { "include": "#mnemonics" },
    { "include": "#prefixes" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#delimiters" }
  ],
  "repository": {
    "mnemonics": {
      "patterns": [
        {
          "name": "keyword.control.mnemonic.scratchlang",
          "match": "\\b(?i:lay|lbl|rst|hlt|run|spk|exc|crc|cmd|clc|imp|new|del|inp|upd|jmp|jlt|jle|jeq|jne|jgt|jge|drw|stp|mov|hsv|rgb|hex|siz|dot|chr|clr|scb|dir|cst|dsp|pla|pch|pan|vol|pow|log|mod|sin|cos|tan|csc|sec|cot|sgn|abs|int|flr|cel|rng)\\b"
        }
      ]
    },
    "prefixes": {
      "patterns": [
        {
          "name": "variable.language.scratchlang",
          "match": "\\bs[0-9]+\\b"
        },
        {
          "name": "variable.language.scratchlang",
          "match": "\\bl[0-9]+\\b"
        },
        {
          "name": "variable.parameter.scratchlang",
          "match": "\\bg[0-9]+\\b"
        },
        {
          "name": "variable.parameter.scratchlang", 
          "match": "\\bv[0-9]+\\b"
        },
        {
          "name": "entity.name.function.scratchlang",
          "match": "\\$[a-zA-Z0-9_]+"
        },
        {
          "name": "support.class.scratchlang",
          "match": "\\b(pen|mus|mth)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.scratchlang",
          "begin": "\"",
          "end": "(\\n|$|;)",
          "patterns": [
            {
              "name": "constant.character.escape.scratchlang",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.scratchlang",
          "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
        }
      ]
    },
    "delimiters": {
      "patterns": [
        {
          "name": "punctuation.terminator.scratchlang",
          "match": ";"
        }
      ]
    }
  },
  "scopeName": "source.scl"
}
